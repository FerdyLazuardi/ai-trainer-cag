# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8011

# ─── Runtime / Infra (set in docker-compose, documented here) ────────────────
# Reduced to 8GB/2vCPU prod fit:
#  - api runs with `--workers 1` (single uvicorn worker).
#  - redis is capped at 512mb (--maxmemory 512mb, allkeys-lru).
# OMP_NUM_THREADS / MKL_NUM_THREADS cap BLAS/onnxruntime intra-op threads to the
# 2 vCPUs so the fastembed BM25 sparse encoder doesn't oversubscribe cores
# (smooths P95). Set on the api + worker services in docker-compose.yml;
# override there if the VM gets more cores.
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5455
POSTGRES_DB=cag_lms
POSTGRES_USER=
POSTGRES_PASSWORD=
# Connection pool: base + overflow = max concurrent connections (10+20=30).
# pool_timeout = seconds a request waits for a free connection before failing
# fast (instead of SQLAlchemy's 30s default hang).
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6391
REDIS_DB=0
REDIS_PASSWORD=


# ─── Embedding ────────────────────────────────────────────────────────────────

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
# OpenRouter is the SOLE LLM provider (no 9Router, no localhost, no Ollama).
# Default URL is the real OpenRouter cloud; override only when routing through
# a different OpenRouter-compatible gateway.
OPENROUTER_API_KEY="" # OpenRouter key
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1" # OpenRouter cloud
# e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct
# Default: deepseek-v4-flash (cheap + fast, paired with alibaba/novita/baidu).
# Switch to gemini-2.5-flash-lite if you need prompt caching (~45% hit rate,
# google-vertex upstream only — set LLM_PROVIDER_ORDER="" to use default).
LLM_MODEL=deepseek/deepseek-v4-flash
# CAG prompt cache note:
# - Empty LLM_PROVIDER_ORDER lets OpenRouter sticky routing maximize provider-cache hits.
# - A manual provider order prioritizes privacy/availability and can reduce cache hit rate.
# - For production, use one verified no-training provider first; track OR Cached/Total Tokens in dashboard.
LLM_PROVIDER_ORDER=alibaba,novita,baidu
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Temperatures ────────────────────────────────────────────────────────────
CHAT_LLM_TEMPERATURE=0.4
EMPATHY_LLM_TEMPERATURE=0.6
CHEAP_LLM_TEMPERATURE=0.3
JUDGE_LLM_TEMPERATURE=0.0
PREPROCESSOR_LLM_TEMPERATURE=0.0
GENERATE_LLM_TEMPERATURE=0.0
# ─── Eval judge (D1/C3) ──────────────────────────────────────────────────────
# DEDICATED faithfulness judge — MUST differ from LLM_MODEL / CHEAP_LLM_MODEL
# (the generator) or startup assert_judge_model_distinct() fails fast.
# deepseek/deepseek-v4-pro requires OpenRouter Privacy →
# "Paid endpoints that may train on request data" = ON, and Zero-Data-Retention
# + Non-frontier = OFF (DeepSeek native trains on data). To swap the judge,
# change ONLY this line. Fallback is used via manual swap, not auto-routing.
JUDGE_LLM_MODEL=deepseek/deepseek-v4-pro
JUDGE_LLM_FALLBACK_MODEL=qwen/qwen-2.5-72b-instruct

# ─── Context Engineering ─────────────────────────────────────────────────────
# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
# Redis exact-answer cache. Moodle CAG sync invalidates it when the active KB
# hash changes.
CACHE_QUERY_TTL_SECONDS=604800
# 12h — must outlive LTM_AFK_THRESHOLD_SECONDS so STM history+summary survive
# long enough for the AFK LTM worker to consume them (2h margin over the 10h
# AFK window). Do not drop below the AFK threshold or LTM sync loses its source.
CONVERSATION_TTL_SECONDS=43200
# AFK window before LTM sync fires. 10h matches "user closed laptop / went
# to sleep" rather than "stepped away for coffee".
LTM_AFK_THRESHOLD_SECONDS=36000
# Per-user LTM episode cap. Guard 1-200.
LTM_MAX_EPISODES_PER_USER=50

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://semiexpositive-renaldo-unvindictively.ngrok-free.dev/
MOODLE_API_TOKEN=

# ─── Retrieval gate ──────────────────────────────────────────────────────────
# ─── Evaluation (LLM-as-judge, async via arq) ────────────────────────────────
# Phase 1: post-hoc faithfulness eval. Uses get_cheap_llm (Gemini Flash Lite),
# persists `eval_faithfulness` score to Postgres (durable; consumed by Streamlit).
# Sample rate keeps cost negligible; always-eval gates catch high-stakes turns.
EVAL_ENABLED=true
EVAL_SAMPLE_RATE=0.10
EVAL_ALWAYS_IF_DENSE_BELOW=0.30
EVAL_ALWAYS_IF_EMPATHY_ABOVE=0.90

# ─── Askfer (Portfolio Chat) ─────────────────────────────────────────────────
# Public chat endpoint for ferdy-fadhil-lazuardi.my.id portfolio.
# Generate a long random secret (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
ASKFER_ADMIN_SECRET=

# ??? Dashboard API ???
# Secret key to access /api/v1/admin/logs
ADMIN_API_KEY=
# URL used by Streamlit (if run locally without secrets)
API_URL=http://localhost:8000/api/v1

# ─── Local-dev auth bypass (DO NOT enable in production) ─────────────────────
# Off by default. When true AND APP_ENV=development, app/api/auth.py
# skips JWT verification and returns a synthetic dev user. Set this in
# your local .env to develop without minting Moodle JWTs. Production
# boot (main.py) refuses to start if this is true under APP_ENV=production.
DEV_BYPASS_ENABLED=false

# ─── Streaq worker hardening ─────────────────────────────────────────────────
# Optional HMAC secret for streaq's pickle payload signing. If set, the
# worker rejects tasks whose pickled payload doesn't match the signature
# (defense in depth against an attacker with Redis-access forging tasks).
# Recommended >=32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Optional in dev; in production the worker logs a loud warning if unset.
STREAQ_SIGNING_SECRET=


# CAG
RETRIEVAL_MODE=cag
CAG_KB_SOURCE=moodle
CAG_MOODLE_COURSE_ID=3
SPREADSHEET_SYNC_URL=
SPREADSHEET_SYNC_TOKEN=""

